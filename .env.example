# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Google Places API (official - no scraping)
GOOGLE_PLACES_API_KEY=your_key_here

# Yelp Fusion API
YELP_API_KEY=your_key_here

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Database
DATABASE_URL=sqlite+aiosqlite:///./restaurant_agent.db

# ChromaDB (Phase 0 - local)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Redis (Phase 1 - leave blank for Phase 0 in-memory sessions)
REDIS_URL=

# Pinecone (Phase 1 - leave blank for Phase 0 ChromaDB)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# Auth
SECRET_KEY=change_this_in_production
API_KEY_HEADER=X-API-Key

# A2A External Agents
CUISINE_EXPERT_AGENT_URL=http://localhost:8002
DIETARY_EXPERT_AGENT_URL=http://localhost:8003

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
